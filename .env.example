# LaunchFolio — AI configuration (optional)
# Copy this file to .env and fill in your values to enable AI-powered parsing.
# Leave blank to use the built-in rule-based parser instead.

# Provider: anthropic | openai
AI_PROVIDER=anthropic

# Model name
#   Anthropic: claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5
#   OpenAI:    gpt-4o | gpt-4o-mini
AI_MODEL=claude-opus-4-7

# Your API key for the chosen provider
# Get it from: https://console.anthropic.com  (Anthropic)
#              https://platform.openai.com    (OpenAI)
AI_API_KEY=
